{
  "name": "sdl3",
  "version": "3.4.2",
  "description": "SDL3 with the LichtFeld Linux X11 compatibility settings",
  "license": "Zlib",
  "supports": "!uwp",
  "dependencies": [
    { "name": "vcpkg-cmake", "host": true },
    { "name": "vcpkg-cmake-config", "host": true }
  ],
  "default-features": ["x11"],
  "features": {
    "x11": { "description": "X11 video backend" },
    "wayland": { "description": "Wayland video backend" },
    "vulkan": { "description": "Vulkan support" },
    "ibus": { "description": "IBus support" }
  }
}
