diff --git a/cmake/onnxruntime_mlas.cmake b/cmake/onnxruntime_mlas.cmake
index 2e9678b7f3..7ca03bc676 100644
--- a/cmake/onnxruntime_mlas.cmake
+++ b/cmake/onnxruntime_mlas.cmake
@@ -659,7 +659,11 @@ if (NOT onnxruntime_ORT_MINIMAL_BUILD)
           ${MLAS_SRC_DIR}/rotary_embedding_kernel_avx2.cpp
           ${MLAS_SRC_DIR}/rotary_embedding_kernel_avx2.cpp
         )
-        if(CMAKE_CXX_COMPILER_VERSION GREATER_EQUAL 13.1 AND NOT(APPLE))
+        # cvtfp16Avx.S uses AVX-NE-convert mnemonics such as vcvtneeph2ps.
+        # GNU binutils 2.38, still common on supported Linux build machines,
+        # rejects those instructions even when GCC accepts -mavxvnni. Keep the
+        # portable MLAS fallback instead of requiring a newer system assembler.
+        if(CMAKE_CXX_COMPILER_VERSION GREATER_EQUAL 13.1 AND NOT(APPLE) AND NOT(CMAKE_SYSTEM_NAME STREQUAL "Linux"))
           set(mlas_platform_srcs_avx2
             ${mlas_platform_srcs_avx2}
             ${MLAS_SRC_DIR}/x86_64/cvtfp16Avx.S
