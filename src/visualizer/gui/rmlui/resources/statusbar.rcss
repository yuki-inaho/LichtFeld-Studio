div {
    display: block;
}

body {
    font-family: Inter;
    font-size: 12dp;
    width: 100%;
    display: flex;
    flex-direction: row;
    align-items: stretch;
    padding: 0;
    margin: 0;
    background-color: transparent;
    overflow: hidden;
}

#status-left {
    flex: 1;
    display: flex;
    flex-direction: row;
    align-items: center;
    overflow: hidden;
}

#status-right {
    display: flex;
    flex-direction: row;
    align-items: center;
    flex-shrink: 0;
}

#training-section,
#splat-section,
#split-section,
#wasd-section,
#zoom-section {
    display: flex;
    flex-direction: row;
    align-items: center;
}

.hidden {
    display: none;
}

#training-section.hidden,
#splat-section.hidden,
#split-section.hidden,
#wasd-section.hidden,
#zoom-section.hidden {
    display: none;
}

/* Within-training separators: 12dp each side */
.separator {
    margin: 0 12dp;
}

/* Section-level separator in training: 20dp left, 12dp right */
#training-section > .separator:first-child {
    margin-left: 20dp;
}

/* Section-level separators for non-training sections: 20dp left, 6dp right */
#splat-section > .separator:first-child,
#split-section > .separator:first-child {
    margin-left: 20dp;
    margin-right: 6dp;
}

.separator.wasd-sep,
.separator.zoom-sep {
    margin-left: 20dp;
    margin-right: 6dp;
}

/* Thin separator in right section */
.separator.thin {
    margin: 0 2dp;
}

#progress-container {
    position: relative;
    width: 360dp;
    height: 16dp;
    overflow: hidden;
    border-radius: 2dp;
    flex-shrink: 0;
    cursor: pointer;
}

#progress-fill {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 0%;
}

#progress-markers {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
}

.progress-marker {
    position: absolute;
    top: 1dp;
    bottom: 1dp;
    width: 6dp;
    margin-left: -3dp;
    border-radius: 2dp;
    cursor: pointer;
}

.progress-marker.is-hovered,
.progress-marker.is-preview {
    top: 0;
    bottom: 0;
    width: 8dp;
    margin-left: -4dp;
}

#progress-text {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    text-align: center;
    line-height: 16dp;
}

#gpu-icon {
    width: 14dp;
    height: 14dp;
    margin-right: 4dp;
    cursor: pointer;
    image-color: rgba(255, 255, 255, 150);
}

#gpu-icon:hover {
    image-color: rgba(255, 255, 255, 215);
}

#gpu-icon.active {
    image-color: rgba(255, 255, 255, 255);
}

#gpu-model {
    display: block;
    min-width: 0;
    max-width: 220dp;
    margin-right: 6dp;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

#lfs-mem {
    margin-right: 0;
}

#gpu-mem {
    margin-right: 0;
}

#fps-value {
    margin-left: 16dp;
}

#fps-label {
    margin-left: 0;
}

#git-commit {
    margin-left: 16dp;
    cursor: pointer;
}

#git-commit:hover {
    text-decoration: underline;
}

#step-label {
    margin-left: 12dp;
    margin-right: 6dp;
}

#loss-label,
#gaussians-label {
    margin-right: 6dp;
}

#eta-label {
    margin-left: 6dp;
    margin-right: 6dp;
}

#split-detail {
    margin-left: 4dp;
}
